class Solution {
public:
    vector<int> getAverages(vector<int>& nums, int k) {
        int n = nums.size();
        vector<int> ans(n, -1);
        long long s = 0;

        for (int i = 0; i < n; i++) {
            s += nums[i];

            // only compute average once we have 2*k+1 elements
            if (i >= 2 * k) {
                ans[i - k] = s / (2 * k + 1);
                s -= nums[i - 2 * k];   // remove oldest element
            }
        }

        return ans;
    } 
};
