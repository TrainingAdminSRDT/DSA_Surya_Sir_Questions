class Solution {
    public int searchInsert(int[] nums, int target) {
        
    int l=0;
    int right= nums.length-1;
        while(l<=right)
        {
          int mid = l+(right-l)/2;
          if(nums[mid]==target)
          {
            return mid;
          }  
          else if(nums[mid]>target)
          {
            right = mid-1;
          }
          else{
            l=mid+1;
          }
         
        }
         return l;
    }
}
