class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int n = nums.length;
        int s=0;
        for(int i=0;i<k;i++)
        {
            s+=nums[i];
        }
        int ms=s;
        for(int j=k;j<n;++j)
        {
            s+= nums[j]-nums[j-k];
            if(s>ms)
            {
                ms= s;
            }
        }
        return (double) ms/k;
    }
}
