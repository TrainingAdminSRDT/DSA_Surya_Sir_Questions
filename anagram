class Solution {
    public boolean isAnagram(String s, String t) {
        int n = s.length();
        if(s.length()!=t.length())
        return false;
         int a[] = new int [26];
        for(int i=0;i<n;i++)
        {
                a[s.charAt(i) - 'a']++;
                a[t.charAt(i) - 'a']--; 
        }
        for(int check:a)
        {
            if(check!=0)
            {
                return false;
            }
        }
        return true;
    }
}
